# --- PORT CONFIGURATION ---
# App port (Must not conflict with your other VPS projects)
APP_PORT=3040
# Database port (External access)
DB_PORT=5438

# --- POSTGRES CONFIGURATION ---
POSTGRES_USER=ss_admin
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=savar_science_society

# --- DATABASE URL ---
# Inside Docker: use 'postgres' as host
# Format: postgresql://USER:PASSWORD@postgres:5432/DBNAME?schema=public
DATABASE_URL=postgresql://ss_admin:replace_with_secure_password@postgres:5432/savar_science_society?schema=public

# --- AUTH CONFIGURATION ---
# Production URL (HTTPS)
NEXTAUTH_URL=https://savarsciencesociety.edu.bd
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_secret_here
AUTH_SECRET=generate_secret_here

# --- OTHER CONFIG ---
# Add any other project-specific variables below
